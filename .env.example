# ── Proxy (runtime, loaded via Node --env-file) ──
PORTA_HOST=127.0.0.1       # Set to Tailscale IP for remote access (run: tailscale ip -4)
PORTA_PORT=3170
PORTA_CORS_ORIGINS=        # Comma-separated allowed origins (usually not needed on Tailscale)

# ── Static file serving (single-port mode) ──
# PORTA_STATIC_DIR=        # Path to web dist/ (e.g. ./packages/web/dist)
#                          # When set, proxy serves web UI + API on one port

# ── Tailscale (optional HTTPS for PWA install) ──
# PORTA_TAILSCALE_HOSTNAME= # MagicDNS hostname (e.g. my-macbook) for tailscale serve

# ── Web (build-time, production only) ──
# VITE_API_BASE=           # Absolute API URL (e.g. http://100.x.x.x:3170)
#                          # Leave unset for local dev — Vite's proxy handles /api/* routing
