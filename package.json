{
  "name": "porta",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:ts": "node scripts/dev-tailscale.mjs",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @porta/web build",
    "build:all": "pnpm build && cp -r packages/web/dist packages/proxy/static",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @porta/web test:e2e"
  }
}
